# =============================================================================
# DevNet workspace .gitignore
# Patterns without a leading "/" apply recursively to ALL subfolders.
# So one .gitignore at the workspace root covers every project below it.
# =============================================================================

# -------- Python --------
# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Build / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
.installed.cfg

# Test / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters caches
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.dmypy.json

# Jupyter
.ipynb_checkpoints/

# -------- Node.js (for any web subprojects) --------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------- Secrets & local config --------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.yml
secrets.yaml

# -------- Logs & temporary files --------
*.log
logs/
*.tmp
*.bak
*.swp
*.swo
*~

# -------- Editors / IDEs --------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# -------- macOS --------
.DS_Store
.AppleDouble
.LSOverride
._*

# -------- Windows / Linux --------
Thumbs.db
ehthumbs.db
Desktop.ini

# -------- Docker --------
docker-compose.override.yml
.docker/

# -------- Misc --------
*.iso
*.tar
*.tar.gz
*.zip
.cache/
